  abstract = {The consistency condition for the nodal derivatives in traditional meshfree Galerkin methods is only the differentiation of the approximation consistency (DAC). One missing part is the consistency between a nodal shape function and its derivatives in terms of the divergence theorem in numerical forms. In this paper, a consistency framework for the meshfree nodal derivatives including the DAC and the discrete divergence consistency (DDC) is proposed. The summation of the linear DDC over the whole computational domain leads to the so-called integration constraint in the literature. A three-point integration scheme using background triangle elements is developed, in which the corrected derivatives are computed by the satisfaction of the quadratic DDC. We prove that such smoothed derivatives also meet the quadratic DAC, and therefore, the proposed scheme possesses the quadratic consistency that leads to its name QC3. Numerical results show that QC3 is the only method that can pass both the linear and the quadratic patch tests and achieves the best performances for all the four examples in terms of stability, convergence, accuracy, and efficiency among all the tested methods. Particularly, it shows a huge improvement for the existing linearly consistent one-point integration method in some examples. Copyright © 2012 John Wiley \& Sons, Ltd.},
  langid = {english},
  keywords = {oft-cited},
  file = {C:\Users\50831\Zotero\storage\GLZ3DN5K\Duan et al. - 2012 - Second-order accurate derivatives and Integration schemes for meshfree methods.pdf}
}

