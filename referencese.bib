@article{liuDynamicalModelCosserat2015,
  title = {Dynamical model of Cosserat elastic rod based on Gauss principle},
  author = {Liu, Yan-Zhu and Yun, Xue and {Department of Engineering Mechanics, Shanghai Jiao Tong University, Shanghai 200240, China;} and {School of Mechanical Engineering, Shanghai Institute of Technology, Shanghai 201418, China}},
