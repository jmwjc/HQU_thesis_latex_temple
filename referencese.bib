  urldate = {2025-09-28},
  abstract = {The highest symmetry in which piezoelectricity was thought to occur is cubic. Here, it is shown that third rank piezoelectricity can occur in isotropic chiral solids. Polarization is coupled via an isotropic third rank tensor to the antisymmetric part of the stress. Asymmetric stress can occur if balanced by moments distributed over area or volume. Such moments occur in heterogeneous solids, in which there exists a characteristic length associated with the microstructure: the Cosserat or micropolar solids. Effects associated with nonzero structure size are predicted, including radial polarization in response to torsion. These effects do not occur in gradient type flexoelectric materials; they are governed by a different tensorial rank and symmetry.},
  langid = {english}
}

