@article{wuAccuracyAnalysisGalerkin2021,
  title = {An Accuracy Analysis of {{Galerkin}} Meshfree Methods Accounting for Numerical Integration},
  author = {Wu, Junchao and Wang, Dongdong},
  date = {2021-03-01},
  journaltitle = {Computer Methods in Applied Mechanics and Engineering},
