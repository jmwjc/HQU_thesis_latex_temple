@article{casqueroVanquishingVolumetricLocking2024,
  title = {Vanquishing Volumetric Locking in Quadratic {{NURBS-based}} Discretizations of Nearly-Incompressible Linear Elasticity: {{CAS}} Elements},
  shorttitle = {Vanquishing Volumetric Locking in Quadratic {{NURBS-based}} Discretizations of Nearly-Incompressible Linear Elasticity},
