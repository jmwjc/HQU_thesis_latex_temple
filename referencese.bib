  author = {Li, Tiantian and Huang, Yu and Wei, Gaoliang and Zhang, Ya-nan and Zhao, Yuanhui and Crittenden, John C. and Li, Chao},
  date = {2020-09},
  journaltitle = {Science of The Total Environment},
