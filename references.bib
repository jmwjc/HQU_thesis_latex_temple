@article{dumont4DRemeshingUsing2018,
  title = {{{4D Remeshing Using}} a {{Space-Time Finite Element Method}} for {{Elastodynamics Problems}}},
  author = {Dumont, Serge and Jourdan, Franck and Madani, Tarik},
  date = {2018-05-25},
  journaltitle = {Mathematical and Computational Applications},
